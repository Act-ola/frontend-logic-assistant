# Optional: configure real project roots. If omitted, the bundled demo React repo is used.
# FRONTEND_ASSISTANT_PROJECTS='[{"id":"order-admin","name":"Order Admin","rootPath":"/absolute/path/to/repo","branch":"main","description":"订单后台"}]'

# Optional: restrict which local directories can be added as projects from the UI.
# Comma-separated absolute paths. If omitted, any readable path is allowed.
# FRONTEND_ASSISTANT_ALLOWED_ROOTS=/srv/repos,/data/frontend-projects

# Optional: switch from deterministic local synthesis to AI SDK Gateway.
# AI_MODE=local
# AI_MODE=gateway
# AI_MODEL=deepseek-v4-pro
# DEEPSEEK_API_KEY=sk-...
