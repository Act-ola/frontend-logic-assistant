# Optional: configure real project roots. If omitted, the bundled demo React repo is used.
# FRONTEND_ASSISTANT_PROJECTS='[{"id":"order-admin","name":"Order Admin","rootPath":"/absolute/path/to/repo","branch":"main","description":"订单后台"}]'

# Simpler alternative: just point to ONE project directory; id/name are derived from the folder name.
# Relative paths are resolved against the process working directory. Ignored if FRONTEND_ASSISTANT_PROJECTS is set.
# FRONTEND_ASSISTANT_ROOT=/Users/you/work/web-slp-page/tools/back-stage

# Optional: switch from deterministic local synthesis to AI SDK Gateway.
# AI_MODE=local
# AI_MODE=gateway
# AI_MODEL=deepseek-v4-pro
# DEEPSEEK_API_KEY=sk-...
